# Django core
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1 localhost

# Admin usernames (space or comma separated)
DJANGO_ADMIN_USERS=admin

# Database (PostgreSQL + PostGIS)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=enb_DB
DB_USER=admin
DB_PASSWORD=admin

# Email (Yandex SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=edunabazar2017@yandex.ru
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=edunabazar2017@yandex.ru

# GeoDjango (adjust paths to your local GDAL/GEOS installation)
# Windows example:
# GDAL_LIBRARY_PATH=C:\OSGeo4W\bin\gdal309.dll
# GEOS_LIBRARY_PATH=C:\OSGeo4W\bin\geos_c.dll
# Ubuntu: leave empty if GDAL is installed system-wide via apt

# SMS (SMSC.ru)
SMSC_LOGIN=your-smsc-login
SMSC_PASSWORD=your-smsc-password

# GigaChat (Sber) — free LLM for news rewriting
# 1. Register at https://developers.sber.ru/studio/workspaces
# 2. Create project → get Client ID and Client Secret
# 3. Base64-encode "client_id:client_secret" and paste below
GIGACHAT_AUTH_KEY=your-base64-encoded-credentials-here

# Production security (ignored when DJANGO_DEBUG=1)
# SECURE_SSL_REDIRECT=1
# SECURE_HSTS_SECONDS=31536000
